{
  "name": "@front-protocol/services",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/scheduler.ts",
    "start": "node dist/scheduler.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@front-protocol/core": "workspace:*",
    "@front-protocol/database": "workspace:*",
    "@front-protocol/solana": "workspace:*",
    "@pump-fun/pump-sdk": "^1.36.0",
    "@pump-fun/pump-swap-sdk": "^1.18.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.0",
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
