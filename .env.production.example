# ──────────────────────────────────────────────
# FRONT PROTOCOL — Production Environment
# ──────────────────────────────────────────────
# Copy this to .env on your production server.
# All values below MUST be changed before deploying.

# ── Database ──
DATABASE_URL="postgresql://frontuser:CHANGE_THIS_PASSWORD@postgres:5432/frontprotocol?schema=public&connection_limit=20"

# ── Redis ──
REDIS_URL="redis://redis:6379"

# ── Solana ──
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_CLUSTER="mainnet-beta"
# REQUIRED: Base58-encoded private key for the protocol's hot wallet
PROTOCOL_WALLET_PRIVATE_KEY="CHANGE_THIS"
# Token mint address — set after deploying the $FRONT SPL token
FRONT_TOKEN_MINT=""

# ── Jupiter ──
JUPITER_API_URL="https://api.jup.ag"
JUPITER_API_KEY=""

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=""

# ── API Server ──
PORT=4001
NODE_ENV=production
# REQUIRED: Generate with `openssl rand -base64 64`
JWT_SECRET="CHANGE_THIS"
# CORS: comma-separated list of allowed origins
CORS_ORIGIN="https://www.front.fun,https://front.fun"

# ── Encryption ──
# REQUIRED: Generate with `openssl rand -hex 32`
ENCRYPTION_KEY="CHANGE_THIS"

# ── Protocol Config (basis points) ──
FLAT_FEE_BONDED=200
FLAT_FEE_RISING=300
FLAT_FEE_DEGEN=500
CREATOR_REVENUE_SHARE=3000
BURN_REVENUE_SHARE=2000
POOL_REVENUE_SHARE=5000
USER_PROFIT_LOCK_BPS=3000
BURN_THRESHOLD_LAMPORTS=1000000000
CREATOR_CLAIM_MINIMUM_LAMPORTS=500000000

# ── Insurance Fund ──
INSURANCE_FUND_TARGET_BPS=200
INSURANCE_DEPOSIT_RATE_BPS=1000

# ── Docker Compose ──
POSTGRES_PASSWORD="CHANGE_THIS"
