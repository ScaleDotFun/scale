# ──────────────────────────────────────────────
# FRONT PROTOCOL — Environment Variables
# ──────────────────────────────────────────────
# Copy this to .env and fill in your values

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/frontprotocol?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Solana
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_CLUSTER="mainnet-beta"
PROTOCOL_WALLET_PRIVATE_KEY="your-base58-encoded-private-key"
FRONT_TOKEN_MINT="your-front-token-mint-address"

# Jupiter
JUPITER_API_URL="https://api.jup.ag"
JUPITER_API_KEY="your-jupiter-api-key"

# Telegram
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# API
API_PORT=3001
API_URL="http://localhost:3001"
JWT_SECRET="your-jwt-secret-change-in-production"

# Frontend
VITE_API_URL="http://localhost:3001"
VITE_WS_URL="ws://localhost:3001"
VITE_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
VITE_SOLANA_CLUSTER="mainnet-beta"

# Protocol Config
FLAT_FEE_BONDED=200
FLAT_FEE_RISING=300
FLAT_FEE_DEGEN=500
CREATOR_REVENUE_SHARE=3000
BURN_REVENUE_SHARE=2000
POOL_REVENUE_SHARE=5000
USER_PROFIT_LOCK_BPS=3000
BURN_THRESHOLD_LAMPORTS=1000000000
CREATOR_CLAIM_MINIMUM_LAMPORTS=500000000

# Insurance Fund
INSURANCE_FUND_TARGET_BPS=200
INSURANCE_DEPOSIT_RATE_BPS=1000

# Encryption (for Telegram bot wallets)
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"
